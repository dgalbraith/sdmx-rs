!/.github/actions/sccache-cache/action.yml
!/.github/actions/setup-nix/
!/.github/actions/setup-nix/action.yml

# Maintainer public keys — trust source for signature verification CI.
# Deny-by-default: re-ignore the directory contents so adding a new maintainer
# key is a deliberate, reviewed act (an explicit allowlist entry below), never
# an accidental commit of a stray .asc file into the CI trust root.
!/.github/maintainer-keys/
/.github/maintainer-keys/*
!/.github/maintainer-keys/dgalbraith.asc

# IDE workspace configuration
!/.vscode/
!/.vscode/settings.json
!/.idea/
!/.idea/rustfmt.toml

# Scratch space and transient files
!/scratch/
/scratch/*
!/scratch/flake.nix
!/scratch/flake.lock

