# XII. Source Code & Workspace Packages
# ==============================================================================
!/crates/
/crates/*
!/crates/**/

# Root-level examples hub
!/examples/
/examples/*
!/examples/README.md

# Crate-level examples
!/crates/*/examples/
!/crates/*/examples/*.rs
!/crates/*/examples/README.md

# Crate-level benchmarks
!/crates/*/benches/
!/crates/*/benches/**/*.rs
!/crates/*/benches/README.md

# Crate-level integration tests
!/crates/*/tests/
!/crates/*/tests/**/*.rs
!/crates/*/tests/README.md

# Curated facade release notes (sdmx-rs only; drives the GitHub Release body)
!/crates/*/release-notes/
!/crates/*/release-notes/*.md
!/crates/*/release-notes/.markdownlint.yaml
# Release-notes template (deny-by-default; only the template.md is tracked)
!/crates/*/release-notes/templates/
/crates/*/release-notes/templates/*
!/crates/*/release-notes/templates/template.md

# Rust source and crate manifests
!/crates/**/*.rs
!/crates/**/Cargo.toml

# Crate-level documentation
!/crates/**/README.md
!/crates/**/CHANGELOG.md

# sdmx-types: XSD contract fragment subsystem (design_docs layer).
!/crates/sdmx-types/xsd-manifest.toml
!/crates/sdmx-types/docs/xsd-fragments/.markdownlint.yaml

# sdmx-types: proptest regression seeds (committed so a discovered failure replays)
!/crates/sdmx-types/src/proptest-regressions/
!/crates/sdmx-types/src/proptest-regressions/*.txt

# sdmx-parsers: spec validation fixtures
!/crates/sdmx-parsers/tests/fixtures/**/*.xml
!/crates/sdmx-parsers/tests/fixtures/**/*.json
!/crates/sdmx-parsers/tests/fixtures/**/*.csv

# sdmx-parsers: fuzz targets
!/crates/sdmx-parsers/fuzz/Cargo.toml
!/crates/sdmx-parsers/fuzz/fuzz_targets/
!/crates/sdmx-parsers/fuzz/fuzz_targets/*.rs

# Baseline seed corpus — cargo-fuzz names files by content hash, no extension.
# /** is intentional and necessary here; extension filtering is not possible.
# Only manually committed seeds land here; fuzzer runtime output remains denied.
!/crates/sdmx-parsers/fuzz/corpus/
!/crates/sdmx-parsers/fuzz/corpus/**

# sdmx-client: integration response mocks only
!/crates/sdmx-client/tests/responses/**/*.xml
!/crates/sdmx-client/tests/responses/**/*.json
!/crates/sdmx-client/tests/responses/**/*.csv

